 &lt;th style="text-align: left"&gt;Required&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;&lt;code&gt;project&lt;/code&gt;&lt;/td&gt;
