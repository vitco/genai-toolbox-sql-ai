 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td&gt;type&lt;/td&gt;
 &lt;td style="text-align: center"&gt;string&lt;/td&gt;
 &lt;td style="text-align: center"&gt;true&lt;/td&gt;
